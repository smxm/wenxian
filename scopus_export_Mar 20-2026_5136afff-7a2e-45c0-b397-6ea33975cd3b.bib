@ARTICLE{Si2023730,
	author = {Si, Lei and Wang, Zhongbin and Li, Jiahao and Wei, Dong and Zhao, Shihao},
	title = {A novel positioning method of anti-punching drilling robot based on the fusion of multi-IMUs and visual image},
	year = {2023},
