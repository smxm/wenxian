  "screening": {
    "batch_size": 3,
    "target_include_count": 70,
    "stop_when_target_reached": false,
    "allow_uncertain": true,
    "retry_times": 8,
    "request_timeout_seconds": 240
  },
  "criteria": {
    "topic": "地下钻进机器人推进与破土机制",
    "inclusion": [
      "研究对象必须为能在土壤、砂土、行星风化层或地表以下介质中推进或挖掘的机器人系统",
      "重点关注推进、破土、钻进、切削、冲击、振动液化、仿生掘进、生长式推进等机制",
      "涉及机构设计、运动学建模、机器人与颗粒介质相互作用或实验验证"
    ],
    "exclusion": [
      "传统大型工业掘进设备",
      "仅在既有管道内移动且不具备自主破土能力的管道机器人",
      "纯水下机器人或纯空中飞行器",
      "无机器人载体背景的纯土力学或纯地质研究"
    ]
  },
  "model": {
    "provider": "deepseek",
    "model_name": "deepseek-chat",
    "api_base_url": "https://api.deepseek.com/v1",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.0,
    "max_tokens": 1536,
    "min_request_interval_seconds": 2.0
  },
  "report": {
    "export_included_bib": true,
    "export_excluded_bib": true,
    "export_unused_bib": true,
    "included_report_format": "md",
    "excluded_report_format": "md",
    "summary_format": "json"
  }
