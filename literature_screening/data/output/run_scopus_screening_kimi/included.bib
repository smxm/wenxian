	journal = {IEEE Robotics and Automation Letters},
	year = {2021},
	title = {Compliant Fins for Locomotion in Granular Media},
	author = {Li, Dongting and Huang, Sichuan and Tang, Yong and Marvi, Hamidreza and Tao, Junliang and Aukes, Daniel M.}
}

@ARTICLE{Naclerio2021,
	note = {Cited by: 153},
	source = {Scopus},
	publication_stage = {Final},
	type = {Article},
	abstract = {Robotic navigation on land, through air, and in water is well researched; numerous robots have successfully demonstrated motion in these environments. However, one frontier for robotic locomotion remains largely unexplored—below ground. Subterranean navigation is simply hard to do, in part because the interaction forces of underground motion are higher than in air or water by orders of magnitude and because we lack for these interactions a robust fundamental physics understanding. We present and test three hypotheses, derived from biological observation and the physics of granular intrusion, and use the results to inform the design of our burrowing robot. These results reveal that (i) tip extension reduces total drag by an amount equal to the skin drag of the body, (ii) granular aeration via tip-based airflow reduces drag with a nonlinear dependence on depth and flow angle, and (iii) variation of the angle of the tip-based flow has a nonmonotonic effect on lift in granular media. Informed by these results, we realize a steerable, root-like soft robot that controls subterranean lift and drag forces to burrow faster than previous approaches by over an order of magnitude and does so through real sand. We also demonstrate that the robot can modulate its pullout force by an order of magnitude and control its direction of motion in both the horizontal and vertical planes to navigate around subterranean obstacles. Our results advance the understanding and capabilities of robotic subterranean locomotion. Copyright © 2021 The Authors, some rights reserved.},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85108376500&doi=10.1126%2Fscirobotics.abe2922&partnerID=40&md5=3bba414610417c46dd078ae35c5a75b5},
	doi = {10.1126/scirobotics.abe2922},
	number = {55},
	volume = {6},
	journal = {Science Robotics},
	year = {2021},
	title = {Controlling subterranean forces enables a fast, steerable, burrowing soft robot},
	author = {Naclerio, Nicholas D. and Karsai, Andras and Murray-Cooper, Mason and Ozkan-Aydin, Yasemin and Aydin, Enes and Goldman, Daniel I. and Hawkes, Elliot W.}
}

@ARTICLE{Zhang2025,
	note = {Cited by: 0; All Open Access; Bronze Open Access},
	source = {Scopus},
	publication_stage = {Article in press},
	type = {Article},
	abstract = {With the complex environment and poor road conditions in underground coal mines, accurate autonomous traveling of hydraulic tracks is a prerequisite for the Anti-Impact Drilling Robot (AIDR) to achieve the goal of unmanned operation. In this paper, an AIDR path-tracking control method that integrates reinforcement learning and manual instruction is proposed to reduce the tracking deviation during traveling and enhance the robustness of the control system. Based on AIDR kinematic modeling, a heading angle reward factor, a lateral deviation reward factor, a steering radius deviation reward factor, and a line speed reward factor are added to the deep deterministic policy gradient (DDPG) reward function. The path-tracking problem is transformed into a multi-objective optimization problem. For the problem of low efficiency of DDPG, manual instruction deep deterministic policy gradient (MI-DDPG) is proposed by optimizing the empirical pool part using a manual instruction method. The results show that compared with the traditional path tracking control method, the method proposed in this paper has a maximum lateral deviation of 0.079 m during straight-line travel and a maximum steering radius deviation of 0.062 m during circular steering of the AIDR under the cinder soft pavement (a typical harsh road condition in underground coal mines). This method can effectively improve the accuracy of AIDR path tracking, especially adapting to the complex and soft road environment of underground coal mines. © 2025 Chinese Automatic Control Society and John Wiley & Sons Australia, Ltd.},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105024430711&doi=10.1002%2Fasjc.70041&partnerID=40&md5=4e4687a48a8ad5f3949f75f7e3266e3f},
	doi = {10.1002/asjc.70041},
	journal = {Asian Journal of Control},
	year = {2025},
	title = {A novel hydraulic track motion control method of anti-impact drilling robot based on MI-DDPG},
	author = {Zhang, Cong and Wang, Zhongbin and Wang, Guofa and Gu, Jinheng and Si, Lei and Wei, Dong}
}

@ARTICLE{Lu2026,
