{
  "project": {
    "name": "new-screening-run",
    "output_dir": "tasks/d002df8e66e9/screening_run/screening_output",
    "save_raw_response": true,
    "save_intermediate_files": true
  },
  "input": {
    "input_files": [
      "tasks/d002df8e66e9/screening_run/inputs/最终整理.ris"
    ],
    "encoding": "auto"
  },
  "dedup": {
    "enabled": true,
    "strict_doi_match": true,
    "normalized_title_exact_match": true,
    "fuzzy_title_match": false
  },
  "screening": {
    "batch_size": 3,
    "target_include_count": 30,
    "stop_when_target_reached": false,
    "allow_uncertain": true,
    "retry_times": 6,
    "request_timeout_seconds": 240
  },
  "criteria": {
    "topic": "弓网离线电气特性、电弧模型（尤其是Cassie及其衍生模型）及MATLAB弓网仿真",
    "inclusion": [
      "必须涉及电气化铁路/高铁的弓网系统 Pantograph-catenary system",
      "核心内容必须探讨弓网离线 Loss of contact/Arcing 引发的电气特性变化 如电压/电流畸变、谐波等",
      "包含电弧的数学/物理建模 如Cassie、Mayr等黑盒模型 或等效电路的计算机仿真 如MATLAB/Simulink 。"
    ],
    "exclusion": [
      "纯机械动力学或受流质量研究 完全无电气分析",
      "非弓网场景的电弧研究 如焊接、断路器电弧，且未说明可移植到弓网",
      "缺乏具体模型公式或仿真/实验波形支撑的纯定性探讨",
      "非中英文文献。"
    ]
  },
  "model": {
    "provider": "deepseek",
    "model_name": "deepseek-reasoner",
    "api_base_url": "https://api.deepseek.com/v1",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.0,
    "max_tokens": 4096,
    "min_request_interval_seconds": 2.0
  },
  "report": {
    "export_included_ris": true,
    "export_excluded_ris": false,
    "export_unused_ris": true,
    "export_included_bib": false,
    "export_excluded_bib": false,
    "export_unused_bib": false,
    "included_report_format": "md",
    "excluded_report_format": "md",
    "summary_format": "json"
  }
}
