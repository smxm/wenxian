	volume = {246},
	journal = {Microbiological Research},
	year = {2021},
	title = {The wheat growth-promoting traits of Ochrobactrum and Pantoea species, responsible for solubilization of different P sources, are ensured by genes encoding enzymes of multiple P-releasing pathways},
