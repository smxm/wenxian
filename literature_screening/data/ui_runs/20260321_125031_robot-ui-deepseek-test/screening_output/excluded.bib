	year = {2021},
	title = {Increased nitrogen use efficiency in crop production can provide economic and environmental benefits},
	author = {Langholtz, Matthew and Davison, Brian H. and Jager, Henriette I. and Eaton, Laurence and Baskaran, Latha M. and Davis, Maggie and Brandt, Craig C.}
}

