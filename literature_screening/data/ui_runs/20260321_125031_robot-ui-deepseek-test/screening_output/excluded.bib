@ARTICLE{Zhang2025,
	note = {Cited by: 3},
	source = {Scopus},
	publication_stage = {Final},
	type = {Article},
	abstract = {Competition between weeds and crops causes crop yield losses, with early-stage weeds having the greatest impact. Labor shortages and concerns about herbicides have led to an urgent need for intelligent weed control robots. One of the difficulties in developing smart weeding robots is the rapid identification of crops and weeds. In this study, Sodium Fluorescein (SF) and Rhodamine B (Rh-B) were used as systemic crop signaling compound to assess its systemic translocation in tomato plants, its effect on tomato vigor and its photostability. Automatic visualization of markers in tomato plants was performed using a light-emitting diode-based fluorescence imaging system with different filters (525 nm for SF and 575 nm for Rh-B). The results showed that crop signaling markers were mainly concentrated in stem and leaf midrib of tomato plants, with better filtering effect of Rh-B treatment on control tomato plants. The fluorescence intensity of tomato plants was positively correlated with treatment concentration and soaking time. However, high doses (including 400, 600 and 800 ppm for SF, 300 ppm for Rh-B) and prolonged treatments (3 days for SF) negatively affected crop vigor, meaning that tomato plants were more tolerant to SF. Without affecting crop growth, SF treatment (200 ppm for 2 days) and Rh-B treatment (200 ppm for 1 day) of tomato plants were able to produce machine-readable fluorescence signals for up to 25 days after transplanting. In combination with computer vision, two methods of distinguishing between crops and weeds were proposed, including segmentation by taking different thresholds for an image and filtering using different filters (575 and 675 nm). The preference was to use the first method due to the disadvantages of the second method in terms of recognition speed and difficulty of algorithm development. Both SF and Rh-B residues in soil won't transfer to weeds. Based on the unique fluorescence property of systemic crop signaling compounds, visualizations of markers in tomato plants after treatments of plant roots with SF and Rh-B offer the possibility of successful application of transplanted crops in early-season weed discrimination. © 2025 Elsevier B.V.},
