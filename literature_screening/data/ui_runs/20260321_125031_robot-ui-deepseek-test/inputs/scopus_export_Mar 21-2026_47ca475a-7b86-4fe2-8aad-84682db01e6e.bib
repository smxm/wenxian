@ARTICLE{Hernández-Arenas2021,
	author = {Hernández-Arenas, Ricardo and Beltrán-Sanahuja, Ana and Navarro-Quirant, Paula and Sanz-Lazaro, Carlos},
	title = {The effect of sewage sludge containing microplastics on growth and fruit development of tomato plants},
	year = {2021},
