@ARTICLE{Hausladen2022,
	author = {Hausladen, Matthew M. and Zhao, Boran and Kubala, Matthew S. and Francis, Lorraine F. and Kowalewski, Timothy M. and Ellison, Christopher J.},
	title = {Synthetic growth by self-lubricated photopolymerization and extrusion inspired by plants and fungi},
