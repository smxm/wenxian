@ARTICLE{Huang2021,
	author = {Huang, Hengliang and Li, Mei and Rizwan, Muhammad and Dai, Zhihua and Yuan, Yuan and Hossain, Md Muzammel and Cao, Menghua and Xiong, Shuanglian and Tu, Shuxin},
	title = {Synergistic effect of silicon and selenium on the alleviation of cadmium toxicity in rice plants},
