@ARTICLE{Cui2021,
	author = {Cui, Si-fan and Yang, Jin-yan},
	title = {Effects of Fluorine on the Growth of Broad Bean (Vicia faba L.) and Maize (Zea mays L.) and the Response of Microbial Community in Soils},
