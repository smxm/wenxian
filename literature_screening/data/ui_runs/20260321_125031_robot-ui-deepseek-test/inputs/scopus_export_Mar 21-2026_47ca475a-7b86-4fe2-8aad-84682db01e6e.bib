@ARTICLE{Zheng20213329,
	author = {Zheng, Xuehao and Ding, Hui and Xu, Ximeng and Liang, Benqiang and Liu, Xingyi and Zhao, Dan and Sun, Lina},
	title = {  In situ phytoremediation of polycyclic aromatic hydrocarbon-contaminated agricultural greenhouse soil using celery},
