@ARTICLE{Kader20212615,
	author = {Kader, Mohammad Abdul and Nakamura, Kimihito and Senge, Masateru and Mojid, Mohammad Abdul},
	title = {Two-dimensional numerical simulations of soil-water and heat flow in a rainfed soybean field under plastic mulching},
	year = {2021},
