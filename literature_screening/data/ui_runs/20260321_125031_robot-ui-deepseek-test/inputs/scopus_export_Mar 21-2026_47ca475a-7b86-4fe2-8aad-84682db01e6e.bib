}

@ARTICLE{Han20241365,
	author = {Han, Gyeol and Seo, Dongoh and Ryu, Jee-Hwan and Kwon, Tae-Hyuk},
	title = {RootBot: root-inspired soft-growing robot for high-curvature directional excavation},
	year = {2024},
	journal = {Acta Geotechnica},
	volume = {19},
	number = {3},
