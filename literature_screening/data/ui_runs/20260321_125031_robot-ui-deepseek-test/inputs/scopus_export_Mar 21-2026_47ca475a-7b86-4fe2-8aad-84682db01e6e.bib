@ARTICLE{Sachin2026,
	author = {Sachin, Sachin and Mondini, Alessio and Mariani, Stefano and Del Dottore, Emanuela and Mazzolai, Barbara},
	title = {BeeRootBot: A Bioinspired Robotic Probe Exhibiting Apical Growth through In Situ Soil Binding},
