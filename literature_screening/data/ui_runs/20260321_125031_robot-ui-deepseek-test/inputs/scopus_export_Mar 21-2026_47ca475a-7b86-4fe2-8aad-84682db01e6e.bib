@ARTICLE{Marmiroli202110769,
	author = {Marmiroli, Marta and Pagano, Luca and Rossi, Riccardo and De La Torre-Roche, Roberto and Lepore, Giovanni Orazio and Ruotolo, Roberta and Gariani, Gianluca and Bonanni, Valentina and Pollastri, Simone and Puri, Alessandro and Gianoncelli, Alessandra and Aquilanti, Giuliana and D'Acapito, Francesco and White, Jason C. and Marmiroli, Nelson},
	title = {Copper Oxide Nanomaterial Fate in Plant Tissue: Nanoscale Impacts on Reproductive Tissues},
