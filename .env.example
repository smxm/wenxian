# Preferred local runtime configuration for this repository.
# Edit the repo-root `.env`; `literature_screening/.env` is kept only as a legacy fallback.

APP_DATA_DIR=./literature_screening/data/api_runs
API_PORT=8000
WEB_PORT=8080

KIMI_API_KEY=
DEEPSEEK_API_KEY=

# Optional compatibility mapping for older Moonshot setups.
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
